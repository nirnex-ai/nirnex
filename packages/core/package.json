{
  "name": "@ai-delivery-os/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/*.js": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "tsc --build && cp src/schema.sql dist/",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
