{
  "name": "@nirnex/core",
  "version": "6.9.0",
  "description": "Nirnex core — database, indexing, and knowledge graph engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scope": {
      "import": "./dist/scope/index.js",
      "types": "./dist/scope/index.d.ts"
    },
    "./dist/*.js": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build && cp src/schema.sql dist/",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nirnex-ai/nirnex.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.4.0"
  }
}
