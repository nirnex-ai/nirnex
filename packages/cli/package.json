{
  "name": "@nirnex/cli",
  "version": "5.0.0",
  "description": "Nirnex CLI — Decision Intelligence for software delivery",
  "type": "module",
  "bin": {
    "nirnex": "./bin/dev.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nirnex-ai/nirnex.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "dependencies": {
    "@nirnex/core": "*",
    "@nirnex/parser": "*"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
