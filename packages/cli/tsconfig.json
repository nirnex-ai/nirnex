{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ai-delivery-os/core": ["../core/src/index.ts"],
      "@ai-delivery-os/core/dist/*.js": ["../core/src/*.ts"],
      "@ai-delivery-os/parser": ["../parser/src/index.ts"],
      "@ai-delivery-os/parser/dist/*.js": ["../parser/src/*.ts"]
    },
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "composite": true
  },
  "references": [
    { "path": "../core" },
    { "path": "../parser" }
  ],
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
